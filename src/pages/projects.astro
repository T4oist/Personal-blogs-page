---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

let projects: any[] = [];
try {
  projects = await getCollection('projects');
} catch (e) {
}
---

<BaseLayout title="Projects | T4oist">
  <div class="max-w-4xl mx-auto px-6 py-24">
    <header class="mb-12 animate-enter">
      <h1 class="text-4xl font-bold mb-4 tracking-tight" style="color: var(--c-text);">
        Projects
      </h1>
      <p class="text-lg" style="color: var(--c-text-3);">
        我的作品与开源项目
      </p>
    </header>
    
    <div class="grid gap-4 md:grid-cols-2">
      {projects.length > 0 ? (
        projects.map((project, index) => (
          <div 
            class="group p-6 rounded-lg transition-all duration-200 hover:translate-y-[-2px] animate-fade"
            style={`background-color: var(--c-bg-soft); border: 1px solid var(--c-border); animation-delay: ${index * 50}ms;`}
          >
            <div class="flex items-start justify-between mb-3">
              <h3 class="text-lg font-semibold group-hover:text-primary transition-colors" style="color: var(--c-text);">
                {project.data.name}
              </h3>
              {project.data.featured && (
                <span class="px-2 py-0.5 text-xs rounded" style="background-color: var(--c-primary); color: white;">
                  Featured
                </span>
              )}
            </div>
            
            <p class="text-sm mb-4" style="color: var(--c-text-3);">
              {project.data.description}
            </p>
            
            <div class="flex flex-wrap gap-2 mb-4">
              {project.data.tech.map((tech: string) => (
                <span class="px-2 py-0.5 text-xs rounded" style="background-color: var(--c-bg-mute); color: var(--c-text-3);">
                  {tech}
                </span>
              ))}
            </div>
            
            <div class="flex gap-4">
              {project.data.github && (
                <a 
                  href={project.data.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-1 text-sm transition-colors hover:text-primary"
                  style="color: var(--c-text-3);"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                  GitHub
                </a>
              )}
              {project.data.link && (
                <a 
                  href={project.data.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-1 text-sm transition-colors hover:text-primary"
                  style="color: var(--c-text-3);"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                  Link
                </a>
              )}
            </div>
          </div>
        ))
      ) : (
        <div class="col-span-full p-8 text-center rounded-lg" style="background-color: var(--c-bg-soft); border: 1px solid var(--c-border);">
          <p style="color: var(--c-text-4);">暂无项目...</p>
        </div>
      )}
    </div>
  </div>
</BaseLayout>
