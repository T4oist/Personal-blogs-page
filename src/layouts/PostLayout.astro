---
import BaseLayout from '@layouts/BaseLayout.astro';
import TableOfContents from '@components/blog/TableOfContents.astro';
import Comments from '@components/common/Comments.astro';
import { GISCUS_CONFIG } from '../config';

interface PostLink {
  slug: string;
  data: { title: string };
}

interface Props {
  title: string;
  description?: string;
  date?: Date;
  tags?: string[];
  readingTime?: string;
  headings?: { depth: number; slug: string; text: string }[];
  prevPost?: PostLink | null;
  nextPost?: PostLink | null;
}

const { title, description, date, tags = [], readingTime, headings = [], prevPost = null, nextPost = null } = Astro.props;
---

<BaseLayout title={`${title} | T4oist`} description={description}>
  <article class="max-w-4xl mx-auto px-6 py-24">
    <div class="mb-6 animate-enter">
      <a href="/blog" class="motion-surface inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm" style="background-color: var(--c-bg-soft); color: var(--c-text-3); border: 1px solid var(--c-border);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        返回
      </a>
    </div>
    
    <header class="mb-12 animate-enter">
      <h1 class="text-3xl md:text-4xl font-bold mb-4 tracking-tight" style="color: var(--c-text);">
        {title}
      </h1>
      <div class="flex flex-wrap items-center gap-4 text-sm" style="color: var(--c-text-4);">
        {date && (
          <time datetime={date.toISOString()}>
            {date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        )}
        {readingTime && <span>· {readingTime}</span>}
      </div>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <span class="px-3 py-1 text-xs rounded-full" style="background-color: var(--c-bg-mute); color: var(--c-text-3);">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </header>
    
    <div class="flex gap-8">
      <div class="flex-1 min-w-0 animate-enter-delay-1">
        <div class="prose">
          <slot />
        </div>

        {(prevPost || nextPost) && (
          <nav class="mt-12 pt-6 border-t grid grid-cols-1 sm:grid-cols-2 gap-4" style="border-color: var(--c-border);">
            {prevPost ? (
              <a
                href={`/blog/${prevPost.slug}`}
                class="motion-surface group p-4 rounded-lg text-left"
                style="background-color: var(--c-bg-soft); border: 1px solid var(--c-border);"
              >
                <span class="block text-xs mb-1" style="color: var(--c-text-4);">← 上一篇</span>
                <span class="text-sm font-medium group-hover:text-primary transition-colors" style="color: var(--c-text-2);">
                  {prevPost.data.title}
                </span>
              </a>
            ) : (
              <div />
            )}
            {nextPost ? (
              <a
                href={`/blog/${nextPost.slug}`}
                class="motion-surface group p-4 rounded-lg text-right"
                style="background-color: var(--c-bg-soft); border: 1px solid var(--c-border);"
              >
                <span class="block text-xs mb-1" style="color: var(--c-text-4);">下一篇 →</span>
                <span class="text-sm font-medium group-hover:text-primary transition-colors" style="color: var(--c-text-2);">
                  {nextPost.data.title}
                </span>
              </a>
            ) : (
              <div />
            )}
          </nav>
        )}

        <Comments 
          repo={GISCUS_CONFIG.repo}
          repoId={GISCUS_CONFIG.repoId}
          category={GISCUS_CONFIG.category}
          categoryId={GISCUS_CONFIG.categoryId}
          mapping={GISCUS_CONFIG.mapping}
          reactionsEnabled={GISCUS_CONFIG.reactionsEnabled}
          emitMetadata={GISCUS_CONFIG.emitMetadata}
          inputPosition={GISCUS_CONFIG.inputPosition}
          theme={GISCUS_CONFIG.theme}
          lang={GISCUS_CONFIG.lang}
        />
      </div>
      <aside class="hidden lg:block w-48 shrink-0">
        <div class="sticky top-24">
          <TableOfContents headings={headings} />
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>
