---
import { getCollection } from 'astro:content';
import dayjs from 'dayjs';

let posts: any[] = [];
try {
  posts = await getCollection('blog', ({ data }) => data.published !== false);
} catch (e) {
}

const sortedPosts = posts.sort((a, b) => 
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categories = [...new Set(posts.map(p => p.data.category).filter(Boolean))];
const tags = [...new Set(posts.flatMap(p => p.data.tags))];

const currentCategory = Astro.url.searchParams.get('category');
const currentTag = Astro.url.searchParams.get('tag');

const filteredPosts = sortedPosts.filter(post => {
  if (currentCategory && post.data.category !== currentCategory) return false;
  if (currentTag && !post.data.tags.includes(currentTag)) return false;
  return true;
});
---

<div class="space-y-8">
  <div class="flex flex-wrap gap-2">
    <a 
      href="/blog"
      class:list={[
        "px-3 py-1 text-sm rounded-full transition-all duration-200",
        !currentCategory 
          ? "text-white" 
          : "hover:text-primary"
      ]}
      style={!currentCategory ? "background-color: var(--c-primary);" : "background-color: var(--c-bg-mute); color: var(--c-text-3);"}
    >
      All
    </a>
    {categories.map((cat) => (
      <a 
        href={`/blog?category=${cat}`}
        class:list={[
          "px-3 py-1 text-sm rounded-full transition-all duration-200",
          currentCategory === cat 
            ? "text-white" 
            : "hover:text-primary"
        ]}
        style={currentCategory === cat ? "background-color: var(--c-primary);" : "background-color: var(--c-bg-mute); color: var(--c-text-3);"}
      >
        {cat}
      </a>
    ))}
  </div>
  
  <div class="space-y-4">
    {filteredPosts.length > 0 ? (
      filteredPosts.map((post, index) => (
        <a 
          href={`/blog/${post.slug}`}
          class="group block p-6 rounded-lg transition-all duration-200 hover:translate-y-[-2px] animate-fade"
          style={`background-color: var(--c-bg-soft); border: 1px solid var(--c-border); animation-delay: ${index * 50}ms;`}
        >
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <h3 class="text-lg font-semibold mb-2 group-hover:text-primary transition-colors" style="color: var(--c-text);">
                {post.data.title}
              </h3>
              
              <p class="text-sm mb-3 line-clamp-2" style="color: var(--c-text-3);">
                {post.data.description}
              </p>
              
              <div class="flex items-center gap-3 text-xs" style="color: var(--c-text-4);">
                <time>{dayjs(post.data.date).format('YYYY-MM-DD')}</time>
                {post.data.category && (
                  <>
                    <span>·</span>
                    <span class="text-primary">{post.data.category}</span>
                  </>
                )}
                {post.data.tags.length > 0 && (
                  <>
                    <span>·</span>
                    <span>{post.data.tags.slice(0, 2).join(', ')}</span>
                  </>
                )}
              </div>
            </div>
          </div>
        </a>
      ))
    ) : (
      <div class="p-8 text-center rounded-lg" style="background-color: var(--c-bg-soft); border: 1px solid var(--c-border);">
        <p style="color: var(--c-text-4);">暂无相关文章...</p>
      </div>
    )}
  </div>
</div>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
