---
import { getCollection } from 'astro:content';
import dayjs from 'dayjs';

let posts: any[] = [];
try {
  posts = await getCollection('blog', ({ data }) => data.published !== false);
} catch (e) {
}

const sortedPosts = posts.sort((a, b) => 
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const filterTags = ['生活', '学习'];
---

<div class="space-y-8">
  <!-- 标签筛选器 -->
  <div class="flex flex-wrap gap-2 mb-8" id="tag-filter">
    <button 
      data-tag="all"
      class="tag-btn px-4 py-2 text-sm rounded-lg active"
      style="background: linear-gradient(135deg, var(--c-primary) 0%, var(--c-primary-dark) 100%); color: white;"
    >
      <span>全部文章</span>
    </button>

    {filterTags.map((tag) => (
      <button
        data-tag={tag}
        class="tag-btn px-4 py-2 text-sm rounded-lg"
        style="background-color: var(--c-bg-mute); color: var(--c-text-3);"
      >
        <span>#{tag}</span>
      </button>
    ))}
  </div>
  
  <!-- 博客文章列表 -->
  <div id="posts-container" class="space-y-4">
    {sortedPosts.map((post, index) => (
      <a 
        href={`/blog/${post.slug}`}
        data-category={post.data.category || ''}
        data-tags={post.data.tags.join('|')}
        class="post-card motion-surface group block p-6 rounded-lg relative overflow-hidden animate-fade"
        style={`background-color: var(--c-bg-soft); border: 1px solid var(--c-border); animation-delay: ${index * 50}ms;`}
      >
        <div class="flex items-start justify-between gap-4 relative z-10">
          <div class="flex-1 min-w-0">
            <h3 class="text-lg font-semibold mb-2 group-hover:text-primary transition-colors" style="color: var(--c-text);">
              {post.data.title}
            </h3>
            
            <p class="text-sm mb-3 line-clamp-2" style="color: var(--c-text-3);">
              {post.data.description}
            </p>
            
            <div class="flex items-center gap-3 text-xs" style="color: var(--c-text-4);">
              <time>{dayjs(post.data.date).format('YYYY-MM-DD')}</time>
              {post.data.category && (
                <>
                  <span>·</span>
                  <span class="text-primary">{post.data.category}</span>
                </>
              )}
              {post.data.tags.length > 0 && (
                <>
                  <span>·</span>
                  <span>{post.data.tags.slice(0, 2).join(', ')}</span>
                </>
              )}
            </div>
          </div>
          
          <!-- 右侧箭头图标 -->
          <div class="post-card-arrow opacity-0 group-hover:opacity-100">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--c-primary);">
              <path d="m9 18 6-6-6-6"/>
            </svg>
          </div>
        </div>
      </a>
    ))}
    
    <!-- 空状态提示 -->
    <div id="empty-state" class="hidden p-8 text-center rounded-lg empty-state" style="background-color: var(--c-bg-soft); border: 1px solid var(--c-border);">
      <p style="color: var(--c-text-4);">暂无相关文章...</p>
    </div>
  </div>
</div>

<script>
function setupTagFilter() {
  const tagButtons = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const postCards = document.querySelectorAll<HTMLElement>('.post-card');
  const emptyState = document.getElementById('empty-state');
  
  // 当前选中的标签
  let currentTag: string = 'all';
  
  tagButtons.forEach(button => {
    if (button.dataset.filterReady === 'true') return;
    button.dataset.filterReady = 'true';

    button.addEventListener('click', () => {
      const selectedTag = button.getAttribute('data-tag');
      
      if (selectedTag === currentTag) return;
      
      currentTag = selectedTag || 'all';
      
      // 更新按钮样式
      tagButtons.forEach(btn => {
        if (btn === button) {
          btn.style.background = 'linear-gradient(135deg, var(--c-primary) 0%, var(--c-primary-dark) 100%)';
          btn.style.backgroundColor = '';
          btn.style.color = 'white';
          btn.style.border = 'none';
          btn.classList.add('active');
        } else {
          btn.style.background = '';
          btn.style.backgroundColor = 'var(--c-bg-mute)';
          btn.style.color = 'var(--c-text-3)';
          btn.style.border = 'none';
          btn.classList.remove('active');
        }
      });
      
      // 筛选文章
      filterPosts(currentTag);
    });
    
  });
  
  function filterPosts(tag: string) {
    let visibleCount = 0;
    
    postCards.forEach((card, index) => {
      const postTags = (card.getAttribute('data-tags') || '').split('|').filter(Boolean);
      const shouldShow = tag === 'all' || postTags.includes(tag);
      
      if (shouldShow) {
        setTimeout(() => {
          card.style.display = 'block';
          card.style.opacity = '0';
          card.style.transform = 'translateY(14px) scale(0.98)';
          
          requestAnimationFrame(() => {
            card.style.transition = 'opacity var(--motion-duration-base) var(--motion-ease), transform var(--motion-duration-base) var(--motion-ease-pop), border-color var(--motion-duration-base) var(--motion-ease), box-shadow var(--motion-duration-base) var(--motion-ease)';
            card.style.opacity = '1';
            card.style.transform = 'translateY(0)';
          });
        }, index * 50);
        
        visibleCount++;
      } else {
        card.style.transition = 'opacity var(--motion-duration-fast) var(--motion-ease), transform var(--motion-duration-fast) var(--motion-ease)';
        card.style.opacity = '0';
        card.style.transform = 'translateY(10px) scale(0.98)';
        
        setTimeout(() => {
          card.style.display = 'none';
        }, 300);
      }
    });
    
    // 显示或隐藏空状态
    setTimeout(() => {
      if (emptyState) {
        if (visibleCount === 0 && tag !== 'all') {
          emptyState.style.display = 'block';
          emptyState.style.animation = 'soft-enter var(--motion-duration-base) var(--motion-ease)';
        } else {
          emptyState.style.display = 'none';
        }
      }
    }, postCards.length * 50 + 300);
  }
}

document.addEventListener('DOMContentLoaded', setupTagFilter);
document.addEventListener('astro:page-load', setupTagFilter);
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .tag-btn {
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition:
      transform var(--motion-duration-base) var(--motion-ease),
      background-color var(--motion-duration-base) var(--motion-ease),
      color var(--motion-duration-base) var(--motion-ease),
      box-shadow var(--motion-duration-base) var(--motion-ease);
  }

  .tag-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(115deg, transparent 0%, transparent 35%, rgba(255, 255, 255, 0.35) 50%, transparent 65%, transparent 100%);
    opacity: 0;
    transform: translateX(-120%);
    transition: opacity var(--motion-duration-base) var(--motion-ease), transform var(--motion-duration-slow) var(--motion-ease);
  }

  .tag-btn:hover {
    transform: translateY(-3px) rotate(-1deg);
    box-shadow: 0 10px 24px color-mix(in srgb, var(--c-primary) 18%, transparent);
  }

  .tag-btn:hover::before {
    opacity: 1;
    transform: translateX(120%);
  }

  .post-card-arrow {
    transform: translateY(2px);
    transition:
      opacity var(--motion-duration-base) var(--motion-ease),
      transform var(--motion-duration-base) var(--motion-ease);
  }

  .post-card:hover .post-card-arrow {
    transform: translateX(4px) translateY(0);
  }
</style>
