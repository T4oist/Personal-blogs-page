---
import dayjs from 'dayjs';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  category?: string;
  slug: string;
  image?: string;
}

const { title, description, date, tags, category, slug, image } = Astro.props;
---

<a 
  href={`/blog/${slug}`}
  class="motion-surface group block p-6 rounded-lg overflow-hidden"
  style="background-color: var(--c-bg-soft); border: 1px solid var(--c-border);"
>
  {image && (
    <div class="mb-4 -mx-6 -mt-6 overflow-hidden rounded-t-xl">
      <img 
        src={image} 
        alt={title}
        loading="lazy"
        decoding="async"
        class="post-image w-full h-48 object-cover"
      />
    </div>
  )}
  
  <div class="space-y-3">
    <h3 class="text-xl font-semibold group-hover:text-primary-400 transition-colors">
      {title}
    </h3>
    
    <p class="text-dark-muted line-clamp-2">
      {description}
    </p>
    
    <div class="flex items-center gap-3 text-sm text-dark-muted">
      <time>{dayjs(date).format('YYYY年MM月DD日')}</time>
      {category && (
        <>
          <span>·</span>
          <span class="text-primary-400">{category}</span>
        </>
      )}
    </div>
    
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 pt-2">
        {tags.map((tag) => (
          <span class="px-2 py-1 text-xs bg-dark-border/50 rounded text-dark-muted hover:text-primary-400 transition-colors">
            #{tag}
          </span>
        ))}
      </div>
    )}
  </div>
</a>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-image {
    transition: opacity var(--motion-duration-base) var(--motion-ease);
  }

  .group:hover .post-image {
    opacity: 0.92;
  }
</style>
