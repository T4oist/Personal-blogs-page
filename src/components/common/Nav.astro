---
import { SITE, NAV_LINKS } from '@/config';

const currentPath = Astro.url.pathname;
---

<nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md border-b" style="background-color: rgba(var(--c-bg), 0.8); border-color: var(--c-border);">
  <div class="max-w-4xl mx-auto px-6">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center group" title={SITE.title}>
        <div class="logo-wrapper">
          <svg class="logo-svg" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
            <circle cx="50" cy="50" r="40" fill="none" stroke="currentColor" stroke-width="2" class="logo-circle"/>
            <line x1="35" y1="50" x2="65" y2="50" stroke="currentColor" stroke-width="2" class="logo-line"/>
            <line x1="50" y1="35" x2="50" y2="65" stroke="currentColor" stroke-width="2" class="logo-line"/>
            <circle cx="50" cy="50" r="4" fill="currentColor" class="logo-dot"/>
          </svg>
        </div>
      </a>
      
      <div class="hidden md:flex items-center gap-1">
        {NAV_LINKS.map((link) => (
          <a 
            href={link.href}
            class:list={[
              "px-4 py-2 text-sm font-medium rounded-lg relative overflow-hidden group nav-link",
              currentPath === link.href ? "text-primary active" : "hover:text-primary"
            ]}
            style={`color: ${currentPath === link.href ? 'var(--c-primary)' : 'var(--c-text-3)'}`}
          >
            {link.name}
            <span class="nav-link-line absolute bottom-1 left-4 right-4 h-px"></span>
          </a>
        ))}
      </div>
      
      <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg nav-link" style="color: var(--c-text-3);" aria-label="Toggle menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
  
  <div id="mobile-menu" class="hidden md:hidden border-t" style="border-color: var(--c-border); background-color: var(--c-bg);">
    <div class="px-6 py-4 space-y-1">
      {NAV_LINKS.map((link) => (
        <a 
          href={link.href}
          class:list={[
            "block px-4 py-2 text-sm font-medium rounded-lg relative overflow-hidden group nav-link",
            currentPath === link.href ? "text-primary active" : "hover:text-primary"
          ]}
          style={`color: ${currentPath === link.href ? 'var(--c-primary)' : 'var(--c-text-3)'}`}
        >
          {link.name}
        </a>
      ))}
    </div>
  </div>
</nav>

<style>
  .logo-wrapper {
    width: 36px;
    height: 36px;
    color: var(--c-text);
    transition: color var(--motion-duration-base) var(--motion-ease), transform var(--motion-duration-base) var(--motion-ease);
  }
  
  .logo-svg {
    width: 100%;
    height: 100%;
  }
  
  .logo-circle,
  .logo-line,
  .logo-dot {
    transition: stroke var(--motion-duration-base) var(--motion-ease), fill var(--motion-duration-base) var(--motion-ease), transform var(--motion-duration-base) var(--motion-ease);
  }
  
  .logo-circle {
    transition: stroke var(--motion-duration-base) var(--motion-ease);
  }
  
  .logo-line {
    transition: stroke var(--motion-duration-base) var(--motion-ease);
  }
  
  .logo-dot {
    transition: fill var(--motion-duration-base) var(--motion-ease), transform var(--motion-duration-base) var(--motion-ease);
    transform-origin: center;
  }
  
  .group:hover .logo-wrapper {
    color: var(--c-primary);
    transform: translateY(-2px);
  }
  
  .group:hover .logo-circle {
    stroke: var(--c-primary);
  }
  
  .group:hover .logo-line {
    stroke: var(--c-primary);
  }
  
  .group:hover .logo-dot {
    fill: var(--c-primary);
  }
  
  .nav-link {
    position: relative;
    cursor: pointer;
    transition:
      background-color var(--motion-duration-base) var(--motion-ease),
      color var(--motion-duration-base) var(--motion-ease),
      transform var(--motion-duration-base) var(--motion-ease);
  }
  
  .nav-link:hover {
    background-color: rgba(66, 184, 131, 0.1);
    transform: translateY(-1px);
  }
  
  .nav-link.active {
    background-color: rgba(66, 184, 131, 0.15);
  }

  .nav-link-line {
    background-color: var(--c-primary);
    opacity: 0;
    transform: scaleX(0.6);
    transform-origin: center;
    transition:
      opacity var(--motion-duration-base) var(--motion-ease),
      transform var(--motion-duration-base) var(--motion-ease);
  }

  .nav-link:hover .nav-link-line,
  .nav-link.active .nav-link-line {
    opacity: 1;
    transform: scaleX(1);
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
