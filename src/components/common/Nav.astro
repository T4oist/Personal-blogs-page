---
import { SITE, NAV_LINKS } from '@/config';

const normalizePath = (path: string) => {
  if (path === '/') return path;
  return path.replace(/\/+$/, '');
};

const currentPath = normalizePath(Astro.url.pathname);
const isActiveLink = (href: string) => {
  const normalizedHref = normalizePath(href);

  if (normalizedHref === '/') {
    return currentPath === normalizedHref;
  }

  return currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
};
---

<nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md border-b" style="background-color: rgba(var(--c-bg), 0.8); border-color: var(--c-border);">
  <div class="max-w-4xl mx-auto px-6">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center group" title={SITE.title}>
        <div class="logo-wrapper">
          <svg class="logo-svg" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
            <circle cx="50" cy="50" r="40" fill="none" stroke="currentColor" stroke-width="2" class="logo-circle"/>
            <line x1="35" y1="50" x2="65" y2="50" stroke="currentColor" stroke-width="2" class="logo-line"/>
            <line x1="50" y1="35" x2="50" y2="65" stroke="currentColor" stroke-width="2" class="logo-line"/>
            <circle cx="50" cy="50" r="4" fill="currentColor" class="logo-dot"/>
          </svg>
        </div>
      </a>
      
      <div class="hidden md:flex items-center gap-1">
        {NAV_LINKS.map((link) => {
          const isActive = isActiveLink(link.href);

          return (
          <a 
            href={link.href}
            class:list={[
              "px-4 py-2 text-sm font-medium rounded-lg transition-all duration-300 relative overflow-hidden group nav-link",
              isActive ? "text-primary active" : "hover:text-primary"
            ]}
            style={`color: ${isActive ? 'var(--c-primary)' : 'var(--c-text-3)'}`}
            aria-current={isActive ? 'page' : undefined}
          >
            {link.name}
            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-gradient-to-r from-transparent via-[var(--c-primary)] to-transparent transition-all duration-300 group-hover:w-full"></span>
          </a>
          );
        })}
      </div>
      
      <button id="mobile-menu-btn" type="button" class="md:hidden p-2 rounded-lg transition-all duration-300 hover:scale-110 hover:bg-[var(--c-bg-soft)]" style="color: var(--c-text-3);" aria-label="Toggle menu" aria-controls="mobile-menu" aria-expanded="false">
        <svg class="w-5 h-5 transition-transform duration-300 group-hover:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
  
  <div id="mobile-menu" class="hidden md:hidden border-t" style="border-color: var(--c-border); background-color: var(--c-bg);">
    <div class="px-6 py-4 space-y-1">
      {NAV_LINKS.map((link) => {
        const isActive = isActiveLink(link.href);

        return (
        <a 
          href={link.href}
          class:list={[
            "block px-4 py-2 text-sm font-medium rounded-lg transition-all duration-300 relative overflow-hidden group nav-link",
            isActive ? "text-primary active" : "hover:text-primary"
          ]}
          style={`color: ${isActive ? 'var(--c-primary)' : 'var(--c-text-3)'}`}
          aria-current={isActive ? 'page' : undefined}
        >
          {link.name}
        </a>
        );
      })}
    </div>
  </div>
</nav>

<style>
  .logo-wrapper {
    width: 36px;
    height: 36px;
    color: var(--c-text);
    transition: color 0.3s ease, transform 0.3s ease;
  }
  
  .logo-svg {
    width: 100%;
    height: 100%;
  }
  
  .logo-circle,
  .logo-line,
  .logo-dot {
    transition: all 0.3s ease;
  }
  
  .logo-circle {
    stroke-dasharray: 251;
    stroke-dashoffset: 0;
    transition: stroke-dashoffset 0.6s ease, stroke 0.3s ease;
  }
  
  .logo-line {
    stroke-dasharray: 30;
    stroke-dashoffset: 0;
    transition: stroke-dashoffset 0.4s ease, stroke 0.3s ease;
  }
  
  .logo-dot {
    transition: fill 0.3s ease, transform 0.3s ease;
    transform-origin: center;
  }
  
  .group:hover .logo-wrapper {
    color: var(--c-primary);
    transform: rotate(15deg) scale(1.1);
  }
  
  .group:hover .logo-circle {
    stroke-dashoffset: 251;
    stroke: var(--c-primary);
    filter: drop-shadow(0 0 8px var(--c-primary));
  }
  
  .group:hover .logo-line {
    stroke-dashoffset: 30;
    stroke: var(--c-primary);
    filter: drop-shadow(0 0 6px var(--c-primary));
  }
  
  .group:hover .logo-dot {
    fill: var(--c-primary);
    transform: scale(2) rotate(180deg);
    filter: drop-shadow(0 0 10px var(--c-primary));
  }
  
  @keyframes logo-draw {
    0% {
      stroke-dashoffset: 251;
    }
    100% {
      stroke-dashoffset: 0;
    }
  }
  
  @keyframes logo-draw-line {
    0% {
      stroke-dashoffset: 30;
    }
    100% {
      stroke-dashoffset: 0;
    }
  }
  
  @keyframes logo-pulse {
    0%, 100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.2);
      opacity: 0.8;
    }
  }
  
  .logo-circle {
    animation: logo-draw 1.5s ease-out forwards;
  }
  
  .logo-line {
    animation: logo-draw-line 1s ease-out 0.5s forwards;
  }
  
  .logo-dot {
    animation: logo-pulse 2s ease-in-out infinite;
  }
  
  .nav-link {
    position: relative;
    cursor: pointer;
    transition:
      background-color var(--motion-duration-base) var(--motion-ease),
      color var(--motion-duration-base) var(--motion-ease),
      transform var(--motion-duration-base) var(--motion-ease-pop),
      box-shadow var(--motion-duration-base) var(--motion-ease);
  }
  
  .nav-link:hover {
    background-color: color-mix(in srgb, var(--c-primary) 10%, transparent);
    transform: translateY(-1px);
    box-shadow: 0 8px 22px color-mix(in srgb, var(--c-primary) 10%, transparent);
  }
  
  .nav-link.active {
    background-color: color-mix(in srgb, var(--c-primary) 14%, transparent);
  }
</style>

<script>
  function setupMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');

    if (!btn || !menu || btn.dataset.menuReady === 'true') return;

    btn.dataset.menuReady = 'true';
    btn.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('hidden') === false;
      btn.setAttribute('aria-expanded', String(isOpen));
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
      });
    });
  }

  document.addEventListener('DOMContentLoaded', setupMobileMenu);
  document.addEventListener('astro:page-load', setupMobileMenu);
</script>
