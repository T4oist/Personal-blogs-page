---
import { SITE } from '@/config';
---

<footer class="py-8 border-t" style="border-color: var(--c-border);">
  <div class="max-w-4xl mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-sm" style="color: var(--c-text-4);">
      <div>
        © {new Date().getFullYear()} {SITE.author}
      </div>
      
      <div class="flex items-center gap-2">
        <span>Powered by</span>
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Astro</a>
      </div>
    </div>
  </div>
</footer>
