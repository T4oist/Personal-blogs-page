---
import { getCollection } from 'astro:content';
import dayjs from 'dayjs';

let posts: any[] = [];
try {
  posts = await getCollection('blog', ({ data }) => data.published !== false);
} catch (e) {
}

const sortedPosts = posts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 6);
---

<section class="pt-4 pb-20 animate-enter-delay-2">
  <div class="flex items-center justify-between mb-5">
    <h2 class="text-xl font-bold tracking-tight" style="color: var(--c-text);">
      Recent Posts
    </h2>
    <a href="/blog" class="text-sm text-primary hover:underline transition-colors">
      View all →
    </a>
  </div>
  
  <div class="grid gap-4 md:grid-cols-2">
    {sortedPosts.length > 0 ? (
      sortedPosts.map((post) => (
        <a 
          href={`/blog/${post.slug}`}
          class="group block p-5 rounded-lg transition-all duration-200 hover:translate-y-[-2px]"
          style="background-color: var(--c-bg-soft); border: 1px solid var(--c-border);"
        >
          <h3 class="text-lg font-semibold mb-2 group-hover:text-primary transition-colors" style="color: var(--c-text);">
            {post.data.title}
          </h3>
          
          <p class="text-sm mb-3 line-clamp-2" style="color: var(--c-text-3);">
            {post.data.description}
          </p>
          
          <div class="flex items-center gap-3 text-xs" style="color: var(--c-text-4);">
            <time>{dayjs(post.data.date).format('YYYY-MM-DD')}</time>
            {post.data.category && (
              <>
                <span>·</span>
                <span class="text-primary">{post.data.category}</span>
              </>
            )}
          </div>
        </a>
      ))
    ) : (
      <div class="col-span-full p-8 text-center rounded-lg" style="background-color: var(--c-bg-soft); border: 1px solid var(--c-border);">
        <p style="color: var(--c-text-4);">暂无文章...</p>
      </div>
    )}
  </div>
</section>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
